generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model GeneratedDocument {
  id        String   @id @default(cuid())
  module    String
  prompt    String   @db.Text
  content   String   @db.Text
  model     String
  createdAt DateTime @default(now())

  @@index([module])
  @@index([createdAt])
  @@map("generated_documents")
}

model CustomModule {
  id        String   @id @default(cuid())
  key       String   @unique
  icon      String
  title     String
  hint      String
  createdAt DateTime @default(now())

  @@map("custom_modules")
}
